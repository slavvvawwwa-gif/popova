# ─── Sanity ──────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Get these from https://www.sanity.io/manage → your project.

# Project ID (Project → Settings → API, or the URL: /manage/personal/project/<ID>)
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Dataset name (usually "production")
NEXT_PUBLIC_SANITY_DATASET=production

# API version — pin to a date; bump deliberately
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Read token — ONLY needed to read drafts or a private dataset.
# Project → API → Tokens → Add token (Viewer permission). Keep it secret.
# Public datasets do not require a token for reading published content.
SANITY_API_READ_TOKEN=

# Shared secret for the Sanity → /api/revalidate webhook (instant content
# updates on the live site). Use any long random string; set the identical
# value in the webhook config at sanity.io/manage and in Vercel env vars.
SANITY_REVALIDATE_SECRET=
